---
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<section id="projects" class="py-20">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-12 text-center">项目作品</h2>
    <div class="grid md:grid-cols-2 gap-8">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="block bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border overflow-hidden"
        >
          {project.data.cover && (
            <img
              src={project.data.cover}
              alt={project.data.title}
              class="w-full h-48 object-cover"
            />
          )}
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-2">{project.data.title}</h3>
            <p class="text-gray-600 text-sm mb-3">{project.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.data.tags.map((tag: string) => (
                <span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded text-xs">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
    {projects.length === 0 && (
      <p class="text-center text-gray-400">暂无项目，敬请期待...</p>
    )}
  </div>
</section>
