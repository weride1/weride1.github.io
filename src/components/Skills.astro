---
const skillGroups = [
  {
    title: '审计与风控',
    skills: ['内部审计', '风险评估', '内控评价', '合规审查', '数据分析', '审计信息化'],
  },
  {
    title: '后端开发',
    skills: ['Python', 'FastAPI', 'Django', 'Flask', 'PostgreSQL', 'MySQL', 'Redis'],
  },
  {
    title: '前端开发',
    skills: ['Vue.js', 'React', 'TypeScript', 'Tailwind CSS', 'Element Plus'],
  },
  {
    title: '运维与工具',
    skills: ['Linux', 'Docker', 'Nginx', 'Git', 'CI/CD', '阿里云'],
  },
];
---

<section id="skills" class="py-20 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-12 text-center">技能</h2>
    <div class="grid md:grid-cols-2 gap-8">
      {skillGroups.map((group) => (
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-4 text-primary">{group.title}</h3>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-sm">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
