---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav';

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
  wide?: boolean;
}

const {
  title,
  description = 'weride1 — 个人门户',
  hideNav = false,
  wide = false,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen">
    {!hideNav && <Nav client:load transition:persist />}

    <main
      class:list={[
        'pb-20 px-4 sm:px-6 lg:px-8 mx-auto',
        hideNav ? 'pt-8' : 'pt-24',
        wide ? 'max-w-7xl' : 'max-w-6xl',
      ]}
    >
      <slot />
    </main>
  </body>
</html>
