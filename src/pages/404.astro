---
import Base from '../layouts/Base.astro';
---

<Base title="404 — weride1" description="页面走丢了">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="glass-container px-10 py-14 text-center max-w-md w-full">
      <div class="text-7xl font-bold tracking-tighter bg-gradient-to-br from-morandi-sage to-morandi-clay bg-clip-text text-transparent mb-4">
        404
      </div>
      <p class="text-base text-gray-700 font-medium mb-2">这里什么都没有</p>
      <p class="text-sm text-gray-400 mb-8">页面可能已经被移走，或者你输错了地址。</p>
      <div class="flex items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium bg-gray-900 text-white hover:bg-gray-800 transition-colors"
        >
          返回首页
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium bg-white/50 text-gray-600 border border-white/40 hover:bg-white/70 transition-colors"
        >
          去看文章
        </a>
      </div>
    </div>
  </div>
</Base>
