---
import Base from '../layouts/Base.astro';
import BlogList from '../components/BlogList';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((a) => ({
    slug: a.slug,
    title: a.data.title,
    date: a.data.date,
    tags: a.data.tags ?? [],
  }));
---

<Base title="Blog — weride1">
  <div class="max-w-3xl mx-auto">
    <header class="mb-12">
      <h1 class="text-3xl font-bold text-gray-800 tracking-tight">文章</h1>
      <p class="text-gray-400 text-sm mt-2">记录技术思考与审计实践</p>
    </header>

    <BlogList articles={articles} client:load />
  </div>
</Base>
