---
import Base from '../layouts/Base.astro';
import DailyFeed from '../components/bento/DailyFeed';
import { getCollection } from 'astro:content';

const feed = (await getCollection('feed'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((f) => ({
    slug: f.slug,
    date: f.data.date,
    mood: f.data.mood,
    content: f.body || '',
  }));
---

<Base title="日报 — weride1">
  <div class="max-w-2xl mx-auto">
    <header class="mb-12">
      <h1 class="text-3xl font-bold text-gray-800 tracking-tight">日报</h1>
      <p class="text-gray-400 text-sm mt-2">记录每天的想法与碎片</p>
    </header>
    <DailyFeed feed={feed} client:load />
  </div>
</Base>
