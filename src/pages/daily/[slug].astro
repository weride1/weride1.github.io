---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { ArrowLeft, ArrowRight, Calendar as CalendarIcon } from 'lucide-react';

export async function getStaticPaths() {
  const feed = (await getCollection('feed')).sort(
    (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
  );

  return feed.map((entry, i) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prev: feed[i - 1] ?? null,
      next: feed[i + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
---

<Base title={`${entry.data.date} — weride1`} description={`${entry.data.date} 的日报`}>
  <article class="max-w-2xl mx-auto pt-4 pb-20">
    <a
      href="/daily"
      class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-mint-600 transition-colors mb-8"
    >
      <ArrowLeft size={12} />
      返回日报列表
    </a>

    <header class="mb-8 flex items-center gap-3">
      <div class="w-10 h-10 rounded-2xl bg-mint-100 border border-white/60 flex items-center justify-center text-mint-600">
        <CalendarIcon size={18} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-gray-800 tracking-tight tabular-nums">
          {entry.data.date}
        </h1>
        {entry.data.mood && (
          <p class="text-sm text-gray-500 mt-0.5">心情 {entry.data.mood}</p>
        )}
      </div>
    </header>

    <div
      class="glass-container p-8 text-sm text-gray-700 leading-[1.9] whitespace-pre-wrap [&_h2]:text-base [&_h2]:font-semibold [&_h2]:text-gray-800 [&_h2]:mt-6 [&_h2]:mb-3 [&_p]:mb-3 [&_a]:underline [&_a]:underline-offset-4 [&_a]:decoration-gray-300 hover:[&_a]:decoration-mint-500"
    >
      <Content />
    </div>

    {(prev || next) && (
      <nav class="mt-8 flex items-center justify-between gap-3">
        {prev ? (
          <a
            href={`/daily/${prev.slug}`}
            class="flex-1 glass-card-sm p-4 group flex items-center gap-3 hover:no-underline"
          >
            <ArrowLeft
              size={14}
              className="text-gray-400 group-hover:text-mint-500 group-hover:-translate-x-0.5 transition-all"
            />
            <div class="min-w-0">
              <div class="text-[10px] tracking-[0.2em] text-gray-400 uppercase">前一天</div>
              <div class="text-xs text-gray-700 tabular-nums truncate">{prev.data.date}</div>
            </div>
          </a>
        ) : (
          <span class="flex-1"></span>
        )}
        {next ? (
          <a
            href={`/daily/${next.slug}`}
            class="flex-1 glass-card-sm p-4 group flex items-center gap-3 justify-end text-right hover:no-underline"
          >
            <div class="min-w-0">
              <div class="text-[10px] tracking-[0.2em] text-gray-400 uppercase">后一天</div>
              <div class="text-xs text-gray-700 tabular-nums truncate">{next.data.date}</div>
            </div>
            <ArrowRight
              size={14}
              className="text-gray-400 group-hover:text-mint-500 group-hover:translate-x-0.5 transition-all"
            />
          </a>
        ) : (
          <span class="flex-1"></span>
        )}
      </nav>
    )}
  </article>
</Base>
