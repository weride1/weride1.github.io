---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<Base title={`${project.data.title} — weride1`}>
  <article class="max-w-3xl mx-auto pt-16 pb-20">
    <header class="mb-12">
      <h1 class="text-2xl font-semibold text-gray-800 tracking-tight mb-3">
        {project.data.title}
      </h1>
      <p class="text-sm text-gray-500 leading-relaxed mb-4">{project.data.description}</p>
      <div class="flex flex-wrap gap-2">
        {project.data.tags.map((tag) => (
          <span class="morandi-tag bg-morandi-sage/20 text-morandi-sage">{tag}</span>
        ))}
      </div>
    </header>
    <div class="glass-container p-8 text-sm text-gray-700 leading-[1.9] [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:text-gray-800 [&_h2]:mt-10 [&_h2]:mb-4 [&_p]:mb-4 [&_ul]:mb-4 [&_ul]:pl-5 [&_ul]:list-disc [&_code]:text-xs [&_code]:bg-white/40 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_pre]:bg-white/40 [&_pre]:backdrop-blur-sm [&_pre]:p-4 [&_pre]:rounded-2xl [&_pre]:overflow-x-auto [&_pre]:text-xs">
      <Content />
    </div>
  </article>
</Base>
