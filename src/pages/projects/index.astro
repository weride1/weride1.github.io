---
import Base from '../../layouts/Base.astro';
import MyProjects from '../../components/bento/MyProjects';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).map((p, i) => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags,
  link: p.data.link,
  featured: p.data.featured,
  size: (i === 0 ? '2x2' : '1x1') as '2x2' | '1x1',
}));
---

<Base title="项目 — weride1">
  <div class="max-w-4xl mx-auto">
    <header class="mb-12">
      <h1 class="text-3xl font-bold text-gray-800 tracking-tight">项目</h1>
      <p class="text-gray-400 text-sm mt-2">用代码解决审计中的实际问题</p>
    </header>
    <MyProjects projects={projects} client:load />
  </div>
</Base>
